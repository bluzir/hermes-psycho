# .env for the relationship profile — copied to $HERMES_HOME/.env and filled in.
# SECRETS ARE NEVER COMMITTED: this is the *.example template only; the real .env
# lives in the volume ($HERMES_HOME/.env) and is gitignored.
#
# What the compose command actually consumes (README step 9):
#   HERMES_UID=$(id -u) HERMES_GID=$(id -g) \
#     docker compose --env-file $HERMES_HOME/.env -f compose.yaml -p hermes up -d
# So the run passes this file via `--env-file` and only the variables BELOW are
# read from it. The project (`-p hermes`), image, and container name are fixed by
# the shared stack / command line — NOT by this file. HERMES_UID/HERMES_GID are
# supplied inline as `$(id -u)`/`$(id -g)` (host user 1101 on the current server),
# so they are not set here either. (The old HERMES_IMAGE / HERMES_HOST_HOME /
# HERMES_COMPOSE_PROJECT=hermes-relationship / HERMES_CONTAINER_NAME=…-gateway /
# HERMES_UID=1000 block was stale — it described a standalone container that no
# longer exists; all profiles share one `hermes` container.)

TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=<owner-telegram-id>
TELEGRAM_HOME_CHANNEL=<chat_id>
LITELLM_API_KEY=       # эмбеддер gbrain через OpenRouter (sk-or-...). Нужен при gbrain.enabled: true.
LITELLM_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=        # legacy alias: install-gbrain.sh может скопировать его в LITELLM_API_KEY, если LITELLM_API_KEY пуст.
XAI_API_KEY=           # Grok STT (stt.provider: xai) + резерв модели. Проще xai-oauth; альтернатива — xai-creds в auth.json.
# Провайдер модели — СМЕННЫЙ: нужен ключ ТОЛЬКО выбранного провайдера
#   (OPENROUTER_API_KEY / ANTHROPIC_API_KEY / XAI_API_KEY). openai-codex/GPT-5.5 — выбор автора.
# Модель — НЕ через этот файл-«ключ здесь»: авторизация через `hermes setup` (или ключ
# провайдера выше) → auth.json. auth.json МОЖЕТ держать несколько авторизаций (напр. codex + xai)
# одновременно — доказано профилем content.
# OPENROUTER_API_KEY=  # раскомментируй, если модель идёт через OpenRouter
# ANTHROPIC_API_KEY=   # раскомментируй, если модель идёт через Anthropic
